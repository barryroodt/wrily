# Authentication — set at least ONE provider API key.
# The default model is anthropic/claude-opus-4-8, so ANTHROPIC_API_KEY is the
# common choice; set MODEL to another provider's slug to use a different key.
ANTHROPIC_API_KEY=sk-ant-...
# Other providers (set the one matching your MODEL slug):
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

GITHUB_TOKEN=ghp_...
PR_NUMBER=123
GITHUB_REPOSITORY=your-org/your-repo
BASE_BRANCH=main
COMMIT_SHA=abc1234def5678

# --- Optional: budget + model --------------------------------------------
# MAX_TOKENS overrides the per-mode token budget (default 2M single / 8M team).
# MAX_TOKENS=8000000
# Allow a model slug not in the rate manifest (persists cost rows as 0, warns).
# WRILY_ALLOW_UNKNOWN_MODEL=1

# --- Optional: local dev --------------------------------------------------
# Run against a locally-built gantry binary instead of the one shipped in the
# image (which bundles the pinned gantry release).
# WRILY_GANTRY_BIN=../gantry/target/release/gantry

# --- Optional: cost tracking via Supabase ---------------------------------
# Set both to persist per-review cost + token usage to a self-hosted Supabase
# project. Bootstrap with `./wrily persistence init`. Leave blank to disable.
# SUPABASE_URL=https://abc.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
